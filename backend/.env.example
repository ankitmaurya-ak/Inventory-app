PORT=5000
NODE_ENV=development
START_WORKERS=true

# PostgreSQL — replace with your credentials
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/inventorydb
DATABASE_SSL=false

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Email (Gmail example — use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Twilio SMS Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OWNER_PHONE_NUMBER=
